app:
  name: "jppt"
  version: "0.1.0"
  debug: false

logging:
  level: "INFO"
  format: "[{time:HH:mm:ss}]{message}"
  json_logs: false
  rotation: "00:00"
  retention: "10 days"

telegram:
  enabled: false
  bot_token: ""
  chat_id: ""
  silent_time:
    enabled: false
    start: "23:00"
    end: "08:00"
    timezone: "Asia/Seoul"
  remote_control:
    enabled: false
    allowed_chat_ids: []
    commands:
      reload: true
      status: true
      help: true
