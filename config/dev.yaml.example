app:
  name: "jppt"
  version: "0.1.0"
  debug: true

logging:
  level: "DEBUG"
  format: "[{time:YYYY-MM-DD HH:mm:ss}][{level}]{message} [{file.name}:{line}]"
  json_logs: false
  rotation: "00:00"
  retention: "10 days"

telegram:
  enabled: false
  bot_token: ""
  chat_id: ""
  silent_time:
    enabled: false
    start: "23:00"
    end: "08:00"
    timezone: "Asia/Seoul"

api:
  host: "127.0.0.1"
  port: 8000
  reload: true
  docs_enabled: true
  cors_origins:
    - "http://localhost:3000"
  trusted_hosts:
    - "localhost"
    - "127.0.0.1"
