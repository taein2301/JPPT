app:
  name: "jppt"
  version: "0.1.0"
  debug: false

logging:
  level: "INFO"
  format: "[{time:YYYY-MM-DD HH:mm:ss}][{level}]{message} [{file.name}:{line}]"
  json_logs: false
  rotation: "00:00"
  retention: "10 days"

telegram:
  enabled: false
  bot_token: ""
  chat_id: ""
  silent_time:
    enabled: false
    start: "23:00"
    end: "08:00"
    timezone: "Asia/Seoul"

api:
  host: "0.0.0.0"
  port: 8000
  reload: false
  docs_enabled: false
  cors_origins: []
  trusted_hosts:
    - "example.com"
